<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cart | Glimora.pk</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
body{font-family:Poppins;background:#fffdfd;}

.table img{
    width:60px;
    border-radius:10px;
}

.btn-custom{
    background:rgb(172,208,242);
    color:white;
    border-radius:25px;
}

.btn-custom:hover{
    background:rgb(135,170,210);
}
</style>
</head>
<body>

<%- include("partials/navbar") %>

<div class="container py-5">

<h2 class="mb-4">Your Cart</h2>

<table class="table align-middle">
<thead>
<tr>
<th>Product</th>
<th>Price</th>
<th>Qty</th>
<th>Total</th>
<th>Action</th>
</tr>
</thead>

<tbody>

<% if (cartItems.length === 0) { %>

<tr>
    <td colspan="5" class="text-center">
        <h5>Your cart is empty.</h5>
    </td>
</tr>

<% } else { %>

    <% let grandTotal = 0; %>

    <% cartItems.forEach(item => { %>

        <% if(item.product){ %>

            <% const total = item.product.price * item.quantity; %>
            <% grandTotal += total; %>

            <tr>

                <td>
                    <img src="/<%= item.product.image %>">
                    <%= item.product.name %>
                </td>

                <td>
                    Rs. <%= item.product.price %>
                </td>

                <td>
                    <%= item.quantity %>
                </td>

                <td>
                    Rs. <%= total %>
                </td>

                <td>
                    <a href="/cart/remove/<%= item._id %>"
                       class="btn btn-danger btn-sm">
                        Remove
                    </a>
                </td>

            </tr>

        <% } %>

    <% }) %>

<% } %>

</tbody>
</table>

<div class="text-end">

<% if (cartItems.length > 0) { %>

    <% let finalTotal = 0; %>

    <% cartItems.forEach(item => { %>
        <% finalTotal += item.product.price * item.quantity; %>
    <% }) %>

    <h4>Total: Rs. <%= finalTotal %></h4>

    <a href="/checkout" class="btn btn-custom px-4 py-2 mt-2">
        Checkout
    </a>

<% } %>

</div>

</div>

</body>
</html>