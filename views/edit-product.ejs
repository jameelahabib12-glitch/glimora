<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product | Glimora.pk</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body{
            background:#f8fbff;
            font-family:'Poppins',sans-serif;
        }

        .card{
            border:none;
            border-radius:20px;
        }

        .btn-custom{
            background:#acd0f2;
            color:#fff;
            border:none;
        }

        .btn-custom:hover{
            background:#8bb9e6;
            color:#fff;
        }
    </style>
</head>

<body>

<%- include("partials/navbar") %>

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow p-4">

                <h2 class="text-center mb-4">
                    Edit Product
                </h2>

                <form action="/api/products/update/<%= product._id %>" method="POST">

                    <div class="mb-3">
                        <label class="form-label">Product Name</label>
                        <input
                            type="text"
                            name="name"
                            class="form-control"
                            value="<%= product.name %>"
                            required
                        >
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                      <textarea
name="description"
class="form-control"
rows="4"
required><%= product.description %></textarea>
                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Price</label>
                           <input
type="number"
name="price"
class="form-control"
value="<%= product.price %>"
required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Stock</label>
                           <input
type="number"
name="stock"
class="form-control"
value="<%= product.stock %>"
required>
                        </div>

                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            Image Path
                        </label>

                       <input
type="text"
name="image"
class="form-control"
value="<%= product.image %>"
required>
                    </div>

                    <div class="d-grid">

                        <button
                            class="btn btn-custom btn-lg"
                            type="submit"
                        >
                            Update Product
                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

</body>
</html>