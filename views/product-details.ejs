<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= product.name %> | Glimora.pk</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body{
            background:#f8fbff;
            font-family:'Poppins',sans-serif;
        }

        .product-box{
            margin-top:50px;
        }

        .product-img{
            width:100%;
            border-radius:15px;
            object-fit:cover;
            max-height:450px;
        }

        .price{
            font-size:2rem;
            font-weight:bold;
            color:#0d6efd;
        }

        .btn-custom{
            background:#acd0f2;
            border:none;
            color:white;
        }

        .btn-custom:hover{
            background:#8bb9e6;
        }
    </style>
</head>

<body>

    <%- include("partials/navbar") %>

<div class="container product-box">

    <a href="/products" class="btn btn-outline-secondary mb-4">
        ← Back to Products
    </a>

    <div class="row">

        <div class="col-md-6">

            <img
                src="/<%= product.image %>"
                class="product-img"
            >

        </div>

        <div class="col-md-6">

            <h1><%= product.name %></h1>

            <p class="text-muted">
                <%= product.description %>
            </p>

            <p class="price">
                Rs. <%= product.price %>
            </p>

            <p>
                Stock:
                <span class="badge bg-success">
                    <%= product.stock %>
                </span>
            </p>

            <form action="/cart/add/<%= product._id %>" method="POST">

    <button type="submit" class="btn btn-dark w-100">
        Add to Cart
    </button>

</form>

        </div>

    </div>

</div>

</body>
</html>