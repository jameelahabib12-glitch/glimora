<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Checkout | Glimora.pk</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
    background:#f8fbff;
    font-family:Poppins,sans-serif;
}

.checkout-box{
    max-width:700px;
    margin:50px auto;
    background:white;
    padding:35px;
    border-radius:15px;
    box-shadow:0 0 20px rgba(0,0,0,.08);
}

.btn-custom{
    background:#acd0f2;
    color:white;
    border:none;
}

.btn-custom:hover{
    background:#89aad2;
}

</style>

</head>
<body>

<%- include("partials/navbar") %>

<div class="container">

<div class="checkout-box">

<h2 class="mb-4 text-center">
Checkout
</h2>

<form action="/checkout" method="POST">

<div class="mb-3">

<label class="form-label">
Full Name
</label>

<input
type="text"
name="customerName"
class="form-control"
required>

</div>

<div class="mb-3">

<label class="form-label">
Email
</label>

<input
type="email"
name="customerEmail"
class="form-control"
required>

</div>

<div class="mb-3">

<label class="form-label">
Phone Number
</label>

<input
type="text"
name="phone"
class="form-control"
required>

</div>

<div class="mb-3">

<label class="form-label">
Delivery Address
</label>

<textarea
name="address"
rows="4"
class="form-control"
required></textarea>

</div>

<button class="btn btn-custom w-100 py-2">

Place Order

</button>

</form>

</div>

</div>

</body>
</html>